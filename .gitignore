# build artifacts
/bin/
/dist/

# go
/vendor/
*.test
*.out
coverage.txt

# editor
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# local
*.local
.env.local

# `.env` at the REPO ROOT is ignored — that's where `mus eln tag` writes
# personal workspace state when run inside the mus checkout for testing.
# `.env` files in subdirs (examples, fixtures, …) stay trackable.
/.env

# Sidecars generated when testing `mus irods upload` inside the repo
# (e.g. `mus irods upload scripts/` writes scripts.mus at the root).
# Anchored at the root only — sidecars in subdirs (fixtures, testdata)
# can still be checked in.
/*.mus

# Archives produced by `mus irods upload <folder> --pack tar.gz`
# inside the repo. Same anchored treatment: ignore at root, allow in
# subdirs (e.g. fixtures) if a test ever needs one.
/*.tar.gz

# user-side data dumps that should never be tracked
*.ndjson
all_gbiomed_mango_data.json
/tmp/
